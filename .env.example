# Copy this file to .env and fill in your values
# .env is gitignored — never commit your real keys!

# Required for AI analysis (get from https://aistudio.google.com/app/api-keys)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override config directory (default: ~/.gitpilot)
# GITPILOT_CONFIG_DIR=/path/to/custom/config
